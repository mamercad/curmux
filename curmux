VERSION = "0.0.0-dev"  # fallback when not in git; release workflow and install.sh bake the tag


def _script_dir():
    try:
        path = __file__
    except NameError:
        path = sys.argv[0] or "."
    return os.path.dirname(os.path.abspath(path)) or "."


def get_version():
    """Version from git describe when run from repo, else VERSION constant (baked at install/release)."""
    try:
        for args in (["git", "describe", "--tags", "--exact-match"], ["git", "describe", "--tags"]):
            r = subprocess.run(args, cwd=_script_dir(), capture_output=True, text=True, timeout=2)
            if r.returncode == 0 and r.stdout:
                return r.stdout.strip().lstrip("v")
    except (OSError, subprocess.TimeoutExpired):
        pass
    return VERSION


HOME = Path.home()
DATA_DIR = HOME / ".curmux"
DB_PATH = DATA_DIR / "curmux.db"
CERT_DIR = DATA_DIR / "tls"
LOG_DIR = DATA_DIR / "logs"
DEFAULT_PORT = 8833
WATCHDOG_INTERVAL = 15
TMUX_PREFIX = "curmux-"
STRIP_ANSI = re.compile(r"\x1b\[[0-9;]*[A-Za-z]|\x1b\].*?\x07|\x1b\[.*?[@-~]")

# ── Database ─────────────────────────────────────────────────────────────

_local = threading.local()


def get_db():
    db = getattr(_local, "db", None)
    if db is None:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        db = sqlite3.connect(str(DB_PATH), timeout=10)
        db.row_factory = sqlite3.Row
        db.execute("PRAGMA journal_mode=WAL")
        db.execute("PRAGMA busy_timeout=5000")
        _local.db = db
    return db


def init_db():
    db = get_db()
    db.executescript("""
        CREATE TABLE IF NOT EXISTS sessions (
            name        TEXT PRIMARY KEY,
            directory   TEXT NOT NULL,
            yolo        INTEGER DEFAULT 0,
            model       TEXT DEFAULT '',
            worktree    INTEGER DEFAULT 0,
            created_at  REAL DEFAULT (unixepoch()),
            started_at  REAL,
            stopped_at  REAL
        );
        CREATE TABLE IF NOT EXISTS tasks (
            id          TEXT PRIMARY KEY,
            project     TEXT NOT NULL DEFAULT '',
            title       TEXT NOT NULL,
            description TEXT DEFAULT '',
            status      TEXT DEFAULT 'todo',
            claimed_by  TEXT,
            claimed_at  REAL,
            created_at  REAL DEFAULT (unixepoch()),
            completed_at REAL
        );
        CREATE TABLE IF NOT EXISTS messages (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            sender      TEXT NOT NULL,
            recipient   TEXT NOT NULL DEFAULT '',
            body        TEXT NOT NULL,
            created_at  REAL DEFAULT (unixepoch()),
            read        INTEGER DEFAULT 0
        );
        CREATE TABLE IF NOT EXISTS memory (
            key         TEXT PRIMARY KEY,
            value       TEXT NOT NULL,
            updated_at  REAL DEFAULT (unixepoch())
        );
        CREATE TABLE IF NOT EXISTS alerts (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            type        TEXT NOT NULL,
            session     TEXT DEFAULT '',
            message     TEXT NOT NULL,
            created_at  REAL DEFAULT (unixepoch())
        );
        CREATE TABLE IF NOT EXISTS stream (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            created_at  REAL DEFAULT (unixepoch()),
            caller      TEXT DEFAULT '',
            method      TEXT NOT NULL,
            path        TEXT NOT NULL
        );
    """)
    db.commit()


# ── Tmux helpers ─────────────────────────────────────────────────────────


def tmux_session_name(name):
    return f"{TMUX_PREFIX}{name}"


def tmux_has_session(name):
    r = subprocess.run(["tmux", "has-session", "-t", tmux_session_name(name)], capture_output=True)
    return r.returncode == 0


def tmux_new_session(name, cmd, cwd, api_url=None):
    api_url = api_url or f"http://localhost:{DEFAULT_PORT}"
    context_val = f"You're in curmux. API base: {api_url}. Your session: {name}. Full API reference: GET {api_url}/api/docs. Agents doc: GET {api_url}/api/agents"
    env_prefix = f"env CURMUX_SESSION={shlex.quote(name)} CURMUX_API_URL={shlex.quote(api_url)} CURMUX_CONTEXT={shlex.quote(context_val)}"
    shell_cmd = " ".join(shlex.quote(c) for c in cmd)
    full_cmd = f"{env_prefix} {shell_cmd}"
    subprocess.run(["tmux", "new-session", "-d", "-s", tmux_session_name(name), "-c", str(cwd), full_cmd], check=True)


def tmux_kill_session(name):
    subprocess.run(["tmux", "kill-session", "-t", tmux_session_name(name)], capture_output=True)


def tmux_send_keys(name, text):
    # Send text literally, then C-m (carriage return) so Cursor Agent TUI submits.
    # Plain "Enter" via tmux can be sent as LF and interpreted as newline-in-input.
    target = tmux_session_name(name)
    subprocess.run(["tmux", "send-keys", "-t", target, "-l", text], capture_output=True)
    subprocess.run(["tmux", "send-keys", "-t", target, "C-m"], capture_output=True)


def tmux_capture(name, lines=500):
    r = subprocess.run(
        ["tmux", "capture-pane", "-t", tmux_session_name(name), "-p", "-S", f"-{lines}"], capture_output=True, text=True
    )
    return r.stdout if r.returncode == 0 else ""


def tmux_list():
    r = subprocess.run(["tmux", "list-sessions", "-F", "#{session_name}"], capture_output=True, text=True)
    if r.returncode != 0:
        return []
    return [s.replace(TMUX_PREFIX, "", 1) for s in r.stdout.strip().splitlines() if s.startswith(TMUX_PREFIX)]


# ── Status detection ─────────────────────────────────────────────────────


def _detect_status(clean_output):
    """Parse cursor agent TUI output to detect session state."""
    if not clean_output or not clean_output.strip():
        return "unknown"
    lines = [ln.strip() for ln in clean_output.splitlines() if ln.strip()]
    if not lines:
        return "unknown"
    tail = "\n".join(lines[-20:]).lower()

    if _at_shell_prompt(clean_output):
        return "exited"

    for pattern in [
        r"do you want to (proceed|continue|run|execute|allow)",
        r"(y/n|yes/no|\[y\]|\[n\])",
        r"approve|permission|confirm",
        r"would you like",
    ]:
        if re.search(pattern, tail):
            return "waiting"

    if any(x in tail for x in ["error", "traceback", "exception", "fatal"]):
        return "error"

    if any(x in tail for x in ["thinking", "generating", "writing", "reading", "running"]):
        return "working"

    return "idle"


def _at_shell_prompt(clean_output):
    if not clean_output:
        return False
    lines = [ln for ln in clean_output.splitlines() if ln.strip()]
    for ln in lines[-5:]:
        ls = ln.strip()
        if re.search(r"[$%#]\s*$", ls) and "\u276f" not in ls:
            return True
    return False


# ── Session management ───────────────────────────────────────────────────


def resolve_name(partial):
    """Resolve prefix match against registered sessions."""
    db = get_db()
    rows = db.execute("SELECT name FROM sessions").fetchall()
    names = [r["name"] for r in rows]
    exact = [n for n in names if n == partial]
    if exact:
        return exact[0]
    matches = [n for n in names if n.startswith(partial)]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"Ambiguous name '{partial}': {', '.join(matches)}", file=sys.stderr)
        sys.exit(1)
    print(f"No session matching '{partial}'", file=sys.stderr)
    sys.exit(1)


def cmd_register(args):
    db = get_db()
    directory = os.path.abspath(os.path.expanduser(args.dir or "."))
    if not os.path.isdir(directory):
        print(f"Directory does not exist: {directory}", file=sys.stderr)
        sys.exit(1)
    db.execute(
        "INSERT OR REPLACE INTO sessions (name, directory, yolo, model, worktree) VALUES (?, ?, ?, ?, ?)",
        (args.name, directory, int(args.yolo), args.model or "", int(args.worktree)),
    )
    db.commit()
    print(
        f"Registered '{args.name}' → {directory}"
        + (" [yolo]" if args.yolo else "")
        + (f" [model={args.model}]" if args.model else "")
        + (" [worktree]" if args.worktree else "")
    )


def cmd_start(args):
    name = resolve_name(args.name)
    db = get_db()
    row = db.execute("SELECT * FROM sessions WHERE name=?", (name,)).fetchone()
    if not row:
        print(f"Session '{name}' not registered", file=sys.stderr)
        sys.exit(1)
    if tmux_has_session(name):
        print(f"Session '{name}' already running")
        return

    cmd_parts = ["cursor-agent"]
    if row["yolo"]:
        cmd_parts.append("--yolo")
    if row["model"]:
        cmd_parts.extend(["--model", row["model"]])
    if row["worktree"]:
        cmd_parts.extend(["--worktree", name])
    cmd_parts.extend(["--workspace", row["directory"]])

    tmux_new_session(name, cmd_parts, row["directory"])
    db.execute("UPDATE sessions SET started_at=? WHERE name=?", (time.time(), name))
    db.commit()
    if getattr(args, "seed", False):
        tmux_send_keys(name, "Read CURMUX_CONTEXT from the environment for curmux coordination.")
    _push_alert("start", name, f"Session '{name}' started")
    print(f"Started '{name}' in {row['directory']}")


def cmd_stop(args):
    name = resolve_name(args.name)
    db = get_db()
    tmux_kill_session(name)
    db.execute("UPDATE sessions SET stopped_at=? WHERE name=?", (time.time(), name))
    db.commit()
    _push_alert("stop", name, f"Session '{name}' stopped")
    print(f"Stopped '{name}'")


def cmd_update(args):
    name = resolve_name(args.name)
    db = get_db()
    row = db.execute("SELECT * FROM sessions WHERE name=?", (name,)).fetchone()
    if not row:
        print(f"Session '{name}' not found", file=sys.stderr)
        sys.exit(1)

    updates = []
    params = []
    if args.dir is not None:
        directory = os.path.abspath(os.path.expanduser(args.dir))
        if not os.path.isdir(directory):
            print(f"Directory does not exist: {directory}", file=sys.stderr)
            sys.exit(1)
        updates.append("directory = ?")
        params.append(directory)
    if args.yolo is not None:
        updates.append("yolo = ?")
        params.append(1 if args.yolo else 0)
    if args.no_yolo:
        updates.append("yolo = ?")
        params.append(0)
    if args.model is not None:
        updates.append("model = ?")
        params.append(args.model)
    if args.worktree is not None:
        updates.append("worktree = ?")
        params.append(1 if args.worktree else 0)
    if args.no_worktree:
        updates.append("worktree = ?")
        params.append(0)

    if not updates:
        print(f"Nothing to update for '{name}'")
        return

    params.append(name)
    db.execute(f"UPDATE sessions SET {', '.join(updates)} WHERE name = ?", params)
    db.commit()
    changed = ", ".join(u.split(" =")[0] for u in updates)
    print(f"Updated '{name}': {changed}")


def cmd_rm(args):
    name = resolve_name(args.name)
    db = get_db()
    if tmux_has_session(name):
        tmux_kill_session(name)
    db.execute("DELETE FROM messages WHERE sender = ? OR recipient = ?", (name, name))
    db.execute("DELETE FROM alerts WHERE session = ?", (name,))
    db.execute("UPDATE tasks SET claimed_by = NULL, claimed_at = NULL WHERE claimed_by = ?", (name,))
    db.execute("DELETE FROM sessions WHERE name = ?", (name,))
    db.commit()
    print(f"Removed '{name}'")


def cmd_attach(args):
    name = resolve_name(args.name)
    if not tmux_has_session(name):
        print(f"Session '{name}' not running", file=sys.stderr)
        sys.exit(1)
    os.execvp("tmux", ["tmux", "attach-session", "-t", tmux_session_name(name)])


def cmd_peek(args):
    name = resolve_name(args.name)
    output = tmux_capture(name, args.lines)
    if output:
        print(output)
    else:
        print(f"No output from '{name}' (not running?)")


def cmd_send(args):
    name = resolve_name(args.name)
    if not tmux_has_session(name):
        print(f"Session '{name}' not running", file=sys.stderr)
        sys.exit(1)
    text = " ".join(args.text)
    tmux_send_keys(name, text)
    print(f"Sent to '{name}': {text[:80]}{'...' if len(text) > 80 else ''}")


def cmd_ls(args):
    db = get_db()
    rows = db.execute("SELECT * FROM sessions ORDER BY name").fetchall()
    if not rows:
        print("No sessions registered. Use: curmux register <name> --dir <path>")
        return
    running = set(tmux_list())
    fmt = args.format if hasattr(args, "format") and args.format else "text"
    if fmt == "json":
        out = []
        for r in rows:
            status = "running" if r["name"] in running else "stopped"
            out.append(dict(r) | {"status": status})
        print(json.dumps(out, indent=2))
    else:
        for r in rows:
            status = "\033[32m● running\033[0m" if r["name"] in running else "\033[90m○ stopped\033[0m"
            flags = []
            if r["yolo"]:
                flags.append("yolo")
            if r["model"]:
                flags.append(f"model={r['model']}")
            if r["worktree"]:
                flags.append("worktree")
            flag_str = f" [{', '.join(flags)}]" if flags else ""
            print(f"  {status}  {r['name']}{flag_str}  {r['directory']}")


def cmd_exec(args):
    """Register + start + send in one shot."""
    db = get_db()
    directory = os.path.abspath(os.path.expanduser(args.dir or "."))
    if not os.path.isdir(directory):
        print(f"Directory does not exist: {directory}", file=sys.stderr)
        sys.exit(1)
    db.execute(
        "INSERT OR REPLACE INTO sessions (name, directory, yolo, model, worktree) VALUES (?, ?, ?, ?, ?)",
        (args.name, directory, int(args.yolo), args.model or "", int(args.worktree)),
    )
    db.commit()

    if tmux_has_session(args.name):
        tmux_kill_session(args.name)
        time.sleep(0.5)

    cmd_parts = ["cursor-agent"]
    if args.yolo:
        cmd_parts.append("--yolo")
    if args.model:
        cmd_parts.extend(["--model", args.model])
    if args.worktree:
        cmd_parts.extend(["--worktree", args.name])
    cmd_parts.extend(["--workspace", directory])

    prompt = " ".join(args.prompt)
    if prompt:
        cmd_parts.append(prompt)

    tmux_new_session(args.name, cmd_parts, directory)
    db.execute("UPDATE sessions SET started_at=? WHERE name=?", (time.time(), args.name))
    db.commit()
    if getattr(args, "seed", False):
        tmux_send_keys(args.name, "Read CURMUX_CONTEXT from the environment for curmux coordination.")
    print(f"Exec '{args.name}' → {directory}: {prompt[:80]}{'...' if len(prompt) > 80 else ''}")


# ── Task board ───────────────────────────────────────────────────────────


def cmd_board(args):
    db = get_db()
    action = args.action if hasattr(args, "action") else "list"
    if action == "ls":
        action = "list"

    if action == "add":
        task_id = f"{args.project or 'TASK'}-{_short_id()}"
        db.execute(
            "INSERT INTO tasks (id, project, title, description) VALUES (?, ?, ?, ?)",
            (task_id, args.project or "", args.title, args.description or ""),
        )
        db.commit()
        print(f"Created {task_id}: {args.title}")

    elif action == "claim":
        row = db.execute(
            "UPDATE tasks SET status='claimed', claimed_by=?, claimed_at=? WHERE id=? AND status='todo' RETURNING *",
            (args.agent, time.time(), args.task_id),
        ).fetchone()
        db.commit()
        if row:
            print(f"Claimed {args.task_id} → {args.agent}")
        else:
            print(f"Cannot claim {args.task_id} (not in 'todo' status)", file=sys.stderr)

    elif action == "done":
        db.execute("UPDATE tasks SET status='done', completed_at=? WHERE id=?", (time.time(), args.task_id))
        db.commit()
        print(f"Completed {args.task_id}")

    else:
        rows = db.execute("SELECT * FROM tasks ORDER BY created_at").fetchall()
        if not rows:
            print("Board is empty. Use: curmux board add --title 'Task description'")
            return
        by_status = {}
        for r in rows:
            by_status.setdefault(r["status"], []).append(r)
        for status in ["todo", "claimed", "done"]:
            items = by_status.get(status, [])
            if items:
                label = {"todo": "📋 Todo", "claimed": "🔨 Claimed", "done": "✅ Done"}[status]
                print(f"\n{label}")
                for t in items:
                    extra = f" ({t['claimed_by']})" if t["claimed_by"] else ""
                    print(f"  {t['id']}  {t['title']}{extra}")


def _short_id():
    return hashlib.sha256(uuid.uuid4().bytes).hexdigest()[:6].upper()


# ── Shell completion ──────────────────────────────────────────────────

_SUBCOMMANDS = [
    "register",
    "start",
    "stop",
    "update",
    "rm",
    "attach",
    "peek",
    "send",
    "exec",
    "ls",
    "list",
    "board",
    "serve",
]
_BOARD_ACTIONS = ["add", "claim", "done", "list", "ls"]


def _session_names_completion(prefix):
    """Return session names from DB that start with prefix. Empty list on error."""
    try:
        db = get_db()
        rows = db.execute("SELECT name FROM sessions ORDER BY name").fetchall()
        return [r["name"] for r in rows if r["name"].startswith(prefix)]
    except Exception:
        return []


def _task_ids_completion(prefix):
    """Return task IDs from DB that start with prefix. Empty list on error."""
    try:
        db = get_db()
        rows = db.execute("SELECT id FROM tasks ORDER BY id").fetchall()
        return [r["id"] for r in rows if r["id"].startswith(prefix)]
    except Exception:
        return []


def _projects_completion(prefix):
    """Return distinct project values that start with prefix. Empty list on error."""
    try:
        db = get_db()
        rows = db.execute("SELECT DISTINCT project FROM tasks WHERE project != '' ORDER BY project").fetchall()
        return [r["project"] for r in rows if r["project"].startswith(prefix)]
    except Exception:
        return []


def get_completions(words, current_word, word_index):
    """
    Return list of completion strings for the given token list and cursor position.
    words[0] is 'curmux'; word_index is 0-based.
    """
    if word_index <= 0:
        return []
    if word_index == 1:
        return [c for c in _SUBCOMMANDS if c.startswith(current_word)]

    cmd = words[1] if len(words) > 1 else None
    if cmd == "board":
        if word_index == 2:
            return [a for a in _BOARD_ACTIONS if a.startswith(current_word)]
        if len(words) > 2 and words[2] in ("claim", "done") and word_index == 3:
            return _task_ids_completion(current_word)
        if len(words) > 2 and words[2] == "add" and word_index >= 3:
            # Complete --project value if previous word is -p or --project
            prev = words[word_index - 1] if word_index > 0 else ""
            if prev in ("--project", "-p"):
                return _projects_completion(current_word)
        return []

    if cmd in ("start", "stop", "update", "attach", "peek", "send", "rm") and word_index == 2:
        return _session_names_completion(current_word)
    if cmd == "exec" and word_index == 2:
        return _session_names_completion(current_word)
    if cmd == "register" and word_index == 2:
        return _session_names_completion(current_word)
    return []


def cmd_completion(args):
    """Print completion script for bash or zsh."""
    if args.shell == "bash":
        print(_BASH_COMPLETION_SCRIPT)
    else:
        print(_ZSH_COMPLETION_SCRIPT)


def _run__complete(argv):
    """Parse argv (shell + rest) and output completions. Used when invoked as curmux __complete ..."""
    if len(argv) < 1 or argv[0] not in ("bash", "zsh"):
        return
    shell = argv[0]
    rest = argv[1:]
    try:
        if shell == "bash":
            line = rest[0] if len(rest) >= 1 else ""
            point = int(rest[1]) if len(rest) >= 2 else 0
            before = line[:point].rstrip()
            words = before.split() if before else []
            if not before or line[:point].endswith(" ") or (point < len(line) and line[point : point + 1].isspace()):
                word_index = len(words)
                current_word = ""
            else:
                word_index = len(words) - 1
                current_word = words[-1] if words else ""
        else:  # zsh
            if not rest:
                return
            current_one_based = int(rest[-1])
            words = rest[:-1]
            word_index = current_one_based - 1
            current_word = words[word_index] if 0 <= word_index < len(words) else ""

        for c in get_completions(words, current_word, word_index):
            print(c)
    except Exception:
        pass


_BASH_COMPLETION_SCRIPT = r"""# Bash completion for curmux
_curmux_complete() {
  mapfile -t COMPREPLY < <(curmux __complete bash "$COMP_LINE" $COMP_POINT 2>/dev/null)
}
complete -F _curmux_complete curmux
"""

_ZSH_COMPLETION_SCRIPT = r"""# Zsh completion for curmux
_curmux() {
  local -a words; words=("${(@)words}")
  local -a reply
  reply=("${(@f)$(curmux __complete zsh "${words[@]}" $CURRENT 2>/dev/null)}")
  [[ -n $reply ]] && compadd -a reply
}
compdef _curmux curmux
"""


# ── Alerts ───────────────────────────────────────────────────────────────


def _push_alert(alert_type, session, message):
    try:
        db = get_db()
        db.execute("INSERT INTO alerts (type, session, message) VALUES (?, ?, ?)", (alert_type, session, message))
        db.commit()
    except Exception:
        pass


def _push_stream(method, path, caller=""):
    try:
        db = get_db()
        db.execute("INSERT INTO stream (method, path, caller) VALUES (?, ?, ?)", (method, path, caller or ""))
        db.commit()
    except Exception:
        pass


# ── Watchdog ─────────────────────────────────────────────────────────────

_session_actions = {}


def watchdog_tick():
    """Single watchdog pass over all running sessions."""
    db = get_db()
    rows = db.execute("SELECT * FROM sessions").fetchall()
    now = time.time()

    for row in rows:
        name = row["name"]
        if not tmux_has_session(name):
            continue

        output = tmux_capture(name, 200)
        if not output:
            continue

        clean = STRIP_ANSI.sub("", output)
        actions = _session_actions.setdefault(name, {})
        status = _detect_status(clean)

        actions["last_status"] = status
        actions["last_check"] = now

        if status != actions.get("prev_status"):
            actions["status_changed_at"] = now
        actions["prev_status"] = status

        # 1. Agent exited to shell → auto-restart with --continue
        if status == "exited" and row["yolo"] and not actions.get("restarting"):
            last_restart = actions.get("last_restart", 0)
            if now - last_restart > 90:
                actions["restarting"] = True
                actions["last_restart"] = now

                def _do_restart(sname=name, sdir=row["directory"], smodel=row["model"], syolo=row["yolo"]):
                    time.sleep(3)
                    cmd_parts = ["cursor-agent", "--continue", "--workspace", sdir]
                    if syolo:
                        cmd_parts.append("--yolo")
                    if smodel:
                        cmd_parts.extend(["--model", smodel])
                    tmux_send_keys(sname, " ".join(cmd_parts))
                    _session_actions.get(sname, {}).pop("restarting", None)

                threading.Thread(target=_do_restart, daemon=True).start()
                _push_alert("auto_restart", name, f"Agent exited in '{name}' — auto-restarting with --continue")

        # 2. Waiting for confirmation in yolo mode → auto-accept
        if status == "waiting" and row["yolo"]:
            wait_since = actions.get("status_changed_at", now)
            last_auto = actions.get("last_auto_accept", 0)
            if now - wait_since > 30 and now - last_auto > 60:
                actions["last_auto_accept"] = now
                tmux_send_keys(name, "y")
                _push_alert("auto_accept", name, f"Auto-accepted confirmation in '{name}'")

        # 3. Stuck detection — no status change for extended period
        changed_at = actions.get("status_changed_at", now)
        if status == "idle" and now - changed_at > 600 and not actions.get("stuck_alerted"):
            actions["stuck_alerted"] = True
            _push_alert("stuck", name, f"Session '{name}' appears stuck (idle >10min)")

        if status != "idle":
            actions.pop("stuck_alerted", None)


def watchdog_loop(stop_event):
    while not stop_event.is_set():
        try:
            watchdog_tick()
        except Exception as e:
            print(f"Watchdog error: {e}", file=sys.stderr)
        stop_event.wait(WATCHDOG_INTERVAL)


