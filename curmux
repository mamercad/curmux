<script>
const API = '';
let currentTab = 'sessions';
let peekSession = null;
let peekInterval = null;

function showTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[onclick*="${tab}"]`).classList.add('active');
  ['sessions','board','alerts'].forEach(t => {
    document.getElementById('tab-'+t).style.display = t===tab ? '' : 'none';
  });
  refresh();
}

async function refresh() {
  if (currentTab === 'sessions') await renderSessions();
  else if (currentTab === 'board') await renderBoard();
  else if (currentTab === 'alerts') await renderAlerts();
}

async function renderSessions() {
  const el = document.getElementById('tab-sessions');
  try {
    const r = await fetch(API+'/api/sessions');
    const sessions = await r.json();
    if (!sessions.length) {
      el.innerHTML = '<div class="empty">No sessions.<br><br>Register one: <code>curmux register myproject --dir ~/project --yolo</code></div>';
      return;
    }
    el.innerHTML = '<div class="sessions-grid">'+sessions.map(s => {
      const st = s.running ? s.detected_status : 'stopped';
      const flags = [];
      if (s.yolo) flags.push('yolo');
      if (s.model) flags.push(s.model);
      if (s.worktree) flags.push('worktree');
      return `<div class="session-card">
        <div class="top">
          <span class="name">${esc(s.name)}</span>
          <span class="status-dot ${st}">${st}</span>
        </div>
        <div class="dir" title="${esc(s.directory)}">${esc(s.directory)}</div>
        ${flags.length ? '<div class="flags">'+flags.map(f=>`<span class="flag">${esc(f)}</span>`).join('')+'</div>' : ''}
        <div class="actions">
          ${s.running
            ? `<button class="btn" onclick="openPeek('${esc(s.name)}')">Peek</button>
               <button class="btn danger" onclick="stopSession('${esc(s.name)}')">Stop</button>`
            : `<button class="btn primary" onclick="startSession('${esc(s.name)}')">Start</button>`}
        </div>
      </div>`;
    }).join('')+'</div>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading sessions</div>';
  }
}

async function renderBoard() {
  const el = document.getElementById('tab-board');
  try {
    const r = await fetch(API+'/api/tasks');
    const tasks = await r.json();
    const cols = {todo:[], claimed:[], done:[]};
    tasks.forEach(t => { if (cols[t.status]) cols[t.status].push(t); });
    el.innerHTML = `
      <div class="add-task-bar">
        <input class="title" id="new-task-title" placeholder="New task title...">
        <input id="new-task-project" placeholder="Project" style="width:120px">
        <button class="btn primary" onclick="addTask()">Add</button>
      </div>
      <div class="board">
        ${['todo','claimed','done'].map(status => `
          <div class="board-col">
            <h3 class="${status}">${status} (${cols[status].length})</h3>
            ${cols[status].map(t => `
              <div class="task-card">
                <div class="task-id">${esc(t.id)}</div>
                <div class="task-title">${esc(t.title)}</div>
                ${t.claimed_by ? `<div class="task-agent">${esc(t.claimed_by)}</div>` : ''}
              </div>
            `).join('') || '<div style="color:var(--text-dim);font-size:13px;padding:8px;">Empty</div>'}
          </div>
        `).join('')}
      </div>`;
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading board</div>';
  }
}

async function renderAlerts() {
  const el = document.getElementById('tab-alerts');
  try {
    const r = await fetch(API+'/api/alerts?limit=50');
    const alerts = await r.json();
    if (!alerts.length) {
      el.innerHTML = '<div class="empty">No alerts yet</div>';
      return;
    }
    el.innerHTML = '<div class="alerts-list">'+alerts.map(a => {
      const d = new Date(a.created_at * 1000);
      const ts = d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      return `<div class="alert-row">
        <span class="alert-time">${ts}</span>
        <span class="alert-type">${esc(a.type)}</span>
        <span class="alert-msg">${esc(a.message)}</span>
      </div>`;
    }).join('')+'</div>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading alerts</div>';
  }
}

async function startSession(name) {
  await fetch(API+`/api/sessions/${name}/start`, {method:'POST'});
  refresh();
}
async function stopSession(name) {
  await fetch(API+`/api/sessions/${name}/stop`, {method:'POST'});
  refresh();
}

function openPeek(name) {
  peekSession = name;
  document.getElementById('peek-title').textContent = name;
  document.getElementById('peek-modal').classList.add('open');
  refreshPeek();
  peekInterval = setInterval(refreshPeek, 3000);
}
function closePeek() {
  document.getElementById('peek-modal').classList.remove('open');
  clearInterval(peekInterval);
  peekSession = null;
}
async function refreshPeek() {
  if (!peekSession) return;
  try {
    const r = await fetch(API+`/api/sessions/${peekSession}/peek?lines=300`);
    const d = await r.json();
    const el = document.getElementById('peek-output');
    el.textContent = d.output || '(no output)';
    el.scrollTop = el.scrollHeight;
  } catch(e) {}
}
async function sendFromPeek() {
  const input = document.getElementById('peek-input');
  if (!input.value.trim() || !peekSession) return;
  await fetch(API+`/api/sessions/${peekSession}/send`, {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({text: input.value})
  });
  input.value = '';
