<script>
const API = '';
const THEME_KEY = 'curmux-theme';
const REFRESH_PARAM = (function(){
  const m = location.search.match(/[?&]refresh=(\\d+)/);
  return m ? Math.max(5, Math.min(300, parseInt(m[1], 10))) : 10;
})();  // seconds; default 10; override with ?refresh=15
const TAB_NAMES = ['sessions','board','alerts','stream'];
let currentTab = 'sessions';
var hashTab = (function(){
  const h = location.hash.slice(1).toLowerCase();
  return TAB_NAMES.indexOf(h) >= 0 ? h : 'sessions';
})();
if (hashTab !== 'sessions') currentTab = hashTab;
let peekSession = null;
let peekInterval = null;

function saveFocus(container) {
  const active = document.activeElement;
  if (!active || !container.contains(active)) return null;
  if (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA') return null;
  if (!active.id) return null;
  return { id: active.id, start: active.selectionStart, end: active.selectionEnd };
}
function restoreFocus(saved) {
  if (!saved) return;
  const el = document.getElementById(saved.id);
  if (!el) return;
  el.focus();
  if (typeof el.selectionStart === 'number') el.setSelectionRange(saved.start, saved.end);
}

function getStoredTheme() {
  try { return localStorage.getItem(THEME_KEY); } catch (e) { return null; }
}
function setStoredTheme(theme) {
  try { localStorage.setItem(THEME_KEY, theme); } catch (e) {}
}
function applyTheme(theme) {
  const body = document.getElementById('dashboard-body');
  const btn = document.getElementById('theme-toggle');
  if (!body || !btn) return;
  if (theme === 'light') {
    body.setAttribute('data-theme', 'light');
    btn.textContent = '🌙';
    btn.title = 'Switch to dark mode';
  } else {
    body.removeAttribute('data-theme');
    btn.textContent = '☀️';
    btn.title = 'Switch to light mode';
  }
}
function toggleTheme() {
  const body = document.getElementById('dashboard-body');
  const next = body && body.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  applyTheme(next);
  setStoredTheme(next);
}
(function initTheme() {
  const stored = getStoredTheme();
  if (stored === 'light' || stored === 'dark') {
    applyTheme(stored);
  } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
    applyTheme('light');
  }
})();
(function initTabFromHash() {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  var el = document.querySelector('.tab[onclick*="'+currentTab+'"]');
  if (el) el.classList.add('active');
  TAB_NAMES.forEach(t => {
    document.getElementById('tab-'+t).style.display = t===currentTab ? '' : 'none';
  });
})();
window.addEventListener('hashchange', function() {
  const h = location.hash.slice(1).toLowerCase();
  if (TAB_NAMES.indexOf(h) >= 0 && h !== currentTab) showTab(h);
});

function showTab(tab) {
  currentTab = tab;
  if (location.hash.slice(1).toLowerCase() !== tab) location.hash = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[onclick*="${tab}"]`).classList.add('active');
  TAB_NAMES.forEach(t => {
    document.getElementById('tab-'+t).style.display = t===tab ? '' : 'none';
  });
  refresh();
}

async function refresh() {
  if (currentTab === 'sessions') await renderSessions();
  else if (currentTab === 'board') await renderBoard();
  else if (currentTab === 'alerts') await renderAlerts();
  else if (currentTab === 'stream') await renderStream();
}

async function renderSessions() {
  const el = document.getElementById('tab-sessions');
  const savedFocus = saveFocus(el);
  try {
    const r = await fetch(API+'/api/sessions');
    const sessions = await r.json();
    if (!sessions.length) {
      el.innerHTML = '<div class="empty">No sessions.<br><br>Register one: <code>curmux register myproject --dir ~/project --yolo</code></div>';
      return;
    }
    el.innerHTML = '<div class="sessions-grid">'+sessions.map(s => {
      const st = s.running ? s.detected_status : 'stopped';
      const flags = [];
      if (s.yolo) flags.push('yolo');
      if (s.model) flags.push(s.model);
      if (s.worktree) flags.push('worktree');
      return `<div class="session-card">
        <div class="top">
          <span class="name">${esc(s.name)}</span>
          <span class="status-dot ${st}">${st}</span>
        </div>
        <div class="dir" title="${esc(s.directory)}">${esc(s.directory)}</div>
        ${flags.length ? '<div class="flags">'+flags.map(f=>`<span class="flag">${esc(f)}</span>`).join('')+'</div>' : ''}
        <div class="actions">
          ${s.running
            ? `<button class="btn" onclick="openPeek('${esc(s.name)}')">Peek</button>
               <button class="btn danger" onclick="stopSession('${esc(s.name)}')">Stop</button>`
            : `<button class="btn primary" onclick="startSession('${esc(s.name)}')">Start</button>`}
        </div>
      </div>`;
    }).join('')+'</div>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading sessions</div>';
  }
  restoreFocus(savedFocus);
}

async function renderBoard() {
  const el = document.getElementById('tab-board');
  const savedFocus = saveFocus(el);
  const prevTitle = document.getElementById('new-task-title')?.value ?? '';
  const prevProject = document.getElementById('new-task-project')?.value ?? '';
  try {
    const r = await fetch(API+'/api/tasks');
    const tasks = await r.json();
    const cols = {todo:[], claimed:[], done:[]};
    tasks.forEach(t => { if (cols[t.status]) cols[t.status].push(t); });
    el.innerHTML = `
      <div class="add-task-bar">
        <input class="title" id="new-task-title" placeholder="New task title...">
        <input id="new-task-project" placeholder="Project" style="width:120px">
        <button class="btn primary" onclick="addTask()">Add</button>
      </div>
      <div class="board">
        ${['todo','claimed','done'].map(status => `
          <div class="board-col">
            <h3 class="${status}">${status} (${cols[status].length})</h3>
            ${cols[status].map(t => `
              <div class="task-card">
                <div class="task-id">${esc(t.id)}</div>
                <div class="task-title">${esc(t.title)}</div>
                ${t.claimed_by ? `<div class="task-agent">${esc(t.claimed_by)}</div>` : ''}
              </div>
            `).join('') || '<div style="color:var(--text-dim);font-size:13px;padding:8px;">Empty</div>'}
          </div>
        `).join('')}
      </div>`;
    const titleIn = document.getElementById('new-task-title');
    const projectIn = document.getElementById('new-task-project');
    if (titleIn) titleIn.value = prevTitle;
    if (projectIn) projectIn.value = prevProject;
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading board</div>';
  }
  restoreFocus(savedFocus);
}

async function renderAlerts() {
  const el = document.getElementById('tab-alerts');
  const savedFocus = saveFocus(el);
  try {
    const r = await fetch(API+'/api/alerts?limit=50');
    const alerts = await r.json();
    if (!alerts.length) {
      el.innerHTML = '<div class="empty">No alerts yet</div>';
      restoreFocus(savedFocus);
      return;
    }
    el.innerHTML = '<div class="alerts-list">'+alerts.map(a => {
      const d = new Date(a.created_at * 1000);
      const ts = d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      return `<div class="alert-row">
        <span class="alert-time">${ts}</span>
        <span class="alert-type">${esc(a.type)}</span>
        <span class="alert-msg">${esc(a.message)}</span>
      </div>`;
    }).join('')+'</div>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading alerts</div>';
  }
  restoreFocus(savedFocus);
}

async function renderStream() {
  const el = document.getElementById('tab-stream');
  const savedFocus = saveFocus(el);
  try {
    const r = await fetch(API+'/api/stream?limit=50');
    const rows = await r.json();
    if (!rows.length) {
      el.innerHTML = '<div class="empty">No API calls yet</div>';
      restoreFocus(savedFocus);
      return;
    }
    el.innerHTML = '<div class="alerts-list">'+rows.map(a => {
      const d = new Date(a.created_at * 1000);
      const ts = d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit',second:'2-digit'});
      const caller = (a.caller && a.caller.trim()) ? esc(a.caller) : '-';
      return `<div class="alert-row stream-row">
        <span class="alert-time">${ts}</span>
        <span class="alert-type">${caller}</span>
        <span class="alert-msg">${esc(a.api_call || (a.method+' '+a.path))}</span>
      </div>`;
    }).join('')+'</div>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error loading stream</div>';
  }
  restoreFocus(savedFocus);
}

async function startSession(name) {
  await fetch(API+`/api/sessions/${name}/start`, {method:'POST'});
  refresh();
}
async function stopSession(name) {
  await fetch(API+`/api/sessions/${name}/stop`, {method:'POST'});
  refresh();
}

function openPeek(name) {
  peekSession = name;
  document.getElementById('peek-title').textContent = name;
  document.getElementById('peek-modal').classList.add('open');
  refreshPeek();
  peekInterval = setInterval(refreshPeek, 3000);
}
function closePeek() {
  document.getElementById('peek-modal').classList.remove('open');
  clearInterval(peekInterval);
  peekSession = null;
}
async function refreshPeek() {
  if (!peekSession) return;
  try {
    const r = await fetch(API+`/api/sessions/${peekSession}/peek?lines=300`);
    const d = await r.json();
    const el = document.getElementById('peek-output');
    el.textContent = d.output || '(no output)';
    el.scrollTop = el.scrollHeight;
  } catch(e) {}
}
async function sendFromPeek() {
  const input = document.getElementById('peek-input');
  if (!input.value.trim() || !peekSession) return;
  await fetch(API+`/api/sessions/${peekSession}/send`, {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({text: input.value})
  });
  input.value = '';
  setTimeout(refreshPeek, 500);
}

async function addTask() {
  const title = document.getElementById('new-task-title').value.trim();
  const project = document.getElementById('new-task-project').value.trim();
  if (!title) return;
  await fetch(API+'/api/tasks', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({title, project})
  });
  document.getElementById('new-task-title').value = '';
  renderBoard();
}

function esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
refresh();
setInterval(refresh, REFRESH_PARAM * 1000);
</script>
