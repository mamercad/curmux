# ── Serve command ────────────────────────────────────────────────────────


def cmd_serve(args):
    port = args.port or DEFAULT_PORT
    no_tls = args.no_tls if hasattr(args, "no_tls") else False

    stop_event = threading.Event()
    wd = threading.Thread(target=watchdog_loop, args=(stop_event,), daemon=True)
    wd.start()

    server = http.server.HTTPServer(("0.0.0.0", port), APIHandler)

    if not no_tls:
        cert, key = ensure_tls()
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(cert, key)
        server.socket = ctx.wrap_socket(server.socket, server_side=True)
        proto = "https"
    else:
        proto = "http"

    def _shutdown(sig, frame):
        stop_event.set()
        threading.Thread(target=server.shutdown, daemon=True).start()

    signal.signal(signal.SIGINT, _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    print(f"\n  curmux v{get_version()}")
    print(f"  Dashboard: {proto}://localhost:{port}")
    print(f"  API:       {proto}://localhost:{port}/api/sessions")
    print(f"  Watchdog:  active (every {WATCHDOG_INTERVAL}s)")
    print("\n  Press Ctrl+C to stop.\n")

    server.serve_forever()


# ── CLI parser ───────────────────────────────────────────────────────────


def build_parser():
    p = argparse.ArgumentParser(
        prog="curmux", description="Cursor Agent Multiplexer — run parallel cursor agent sessions"
    )
    p.add_argument("-v", "--version", action="version", version=f"curmux {get_version()}")
    sub = p.add_subparsers(dest="command")

    # register
    reg = sub.add_parser("register", help="Register a new session")
    reg.add_argument("name", help="Session name")
    reg.add_argument("--dir", "-d", help="Working directory (default: cwd)")
    reg.add_argument("--yolo", action="store_true", help="Run in yolo/force mode")
    reg.add_argument("--model", "-m", help="Model to use (e.g. sonnet-4)")
    reg.add_argument("--worktree", "-w", action="store_true", help="Use git worktree isolation")

    # start
    st = sub.add_parser("start", help="Start a registered session")
    st.add_argument("name", help="Session name (prefix match)")

    # update
    up = sub.add_parser("update", aliases=["set"], help="Update session settings")
    up.add_argument("name", help="Session name (prefix match)")
    up.add_argument("--dir", "-d", default=None, help="Change working directory")
    up.add_argument("--yolo", action="store_true", default=None, help="Enable yolo mode")
    up.add_argument("--no-yolo", action="store_true", default=False, help="Disable yolo mode")
    up.add_argument("--model", "-m", default=None, help="Change model")
    up.add_argument("--worktree", "-w", action="store_true", default=None, help="Enable worktree isolation")
    up.add_argument("--no-worktree", action="store_true", default=False, help="Disable worktree isolation")

    # stop
    sp = sub.add_parser("stop", help="Stop a running session")
    sp.add_argument("name", help="Session name (prefix match)")

    # rm
    rm = sub.add_parser("rm", aliases=["remove", "del"], help="Remove a session")
    rm.add_argument("name", help="Session name (prefix match)")

    # attach
    at = sub.add_parser("attach", help="Attach to a session's tmux")
    at.add_argument("name", help="Session name (prefix match)")

    # peek
    pk = sub.add_parser("peek", help="View session output without attaching")
    pk.add_argument("name", help="Session name (prefix match)")
    pk.add_argument("--lines", "-n", type=int, default=100, help="Lines to capture")

    # send
    sd = sub.add_parser("send", help="Send text to a session")
    sd.add_argument("name", help="Session name (prefix match)")
    sd.add_argument("text", nargs="+", help="Text to send")

    # exec
    ex = sub.add_parser("exec", help="Register + start + send in one shot")
    ex.add_argument("name", help="Session name")
    ex.add_argument("--dir", "-d", help="Working directory (default: cwd)")
    ex.add_argument("--yolo", action="store_true", help="Run in yolo/force mode")
    ex.add_argument("--model", "-m", help="Model to use")
    ex.add_argument("--worktree", "-w", action="store_true", help="Use git worktree isolation")
    ex.add_argument("prompt", nargs="*", help="Initial prompt")

    # ls
    ls = sub.add_parser("ls", help="List sessions")
    ls.add_argument("--format", "-f", choices=["text", "json"], default="text")

    # board
    bd = sub.add_parser("board", help="Task board")
    bd_sub = bd.add_subparsers(dest="action")
    bd_add = bd_sub.add_parser("add", help="Add a task")
    bd_add.add_argument("--title", "-t", required=True, help="Task title")
    bd_add.add_argument("--description", help="Task description")
    bd_add.add_argument("--project", "-p", help="Project prefix")
    bd_claim = bd_sub.add_parser("claim", help="Claim a task")
    bd_claim.add_argument("task_id", help="Task ID")
    bd_claim.add_argument("--agent", "-a", required=True, help="Agent/session name")
    bd_done = bd_sub.add_parser("done", help="Mark a task done")
    bd_done.add_argument("task_id", help="Task ID")
    bd_sub.add_parser("list", help="List all tasks")

    # serve
    sv = sub.add_parser("serve", help="Start web dashboard + watchdog")
    sv.add_argument("--port", "-p", type=int, default=DEFAULT_PORT, help=f"Port (default: {DEFAULT_PORT})")
    sv.add_argument("--no-tls", action="store_true", help="Disable TLS")

    return p


def main():
    init_db()
    p = build_parser()
    args = p.parse_args()

    dispatch = {
        "register": cmd_register,
        "update": cmd_update,
        "set": cmd_update,
        "start": cmd_start,
        "stop": cmd_stop,
        "rm": cmd_rm,
        "remove": cmd_rm,
        "del": cmd_rm,
        "attach": cmd_attach,
        "peek": cmd_peek,
        "send": cmd_send,
        "exec": cmd_exec,
        "ls": cmd_ls,
        "board": cmd_board,
        "serve": cmd_serve,
    }

    if not args.command:
        p.print_help()
        sys.exit(0)

    fn = dispatch.get(args.command)
    if fn:
        fn(args)
    else:
        p.print_help()


if __name__ == "__main__":
    main()
